#!/bin/sh

set -eu

repo_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
dotfiles_dir="$repo_dir/dotfiles"

printf "\nCreating symlinks...\n\n"

mkdir -p "$HOME/.config/niri" "$HOME/.config/iamb" "$HOME/.gnupg"

ln -is "$dotfiles_dir/niri/config.kdl" "$HOME/.config/niri/"
ln -is "$dotfiles_dir/gitconfig" "$HOME/.gitconfig"
ln -is "$dotfiles_dir/gitignore" "$HOME/.gitignore"
ln -is "$dotfiles_dir/iamb/config.toml" "$HOME/.config/iamb/"
ln -is "$dotfiles_dir/scdaemon.conf" "$HOME/.gnupg/"
